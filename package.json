{
  "name": "api",
  "version": "1.0.0",
  "description": "API REST TSIW — Limpeza de Praias",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch app.js",
    "start": "node app.js",
    "db:seed": "node scripts/seed-database.mjs",
    "db:migrate-waste-org": "node scripts/migrate-waste-org-scope.mjs",
    "db:fix-indexes": "node scripts/fix-db-indexes.mjs",
    "test": "node --test tests/unit/*.test.mjs tests/integration/*.test.mjs",
    "test:integration": "node --test tests/integration/*.test.mjs",
    "test:unit": "node --test tests/unit/*.test.mjs",
    "test:watch": "node --test --watch tests/integration/*.test.mjs"
  },
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "mysql2": "^3.22.0",
    "pdfkit": "^0.19.0",
    "sequelize": "^6.37.8"
  },
  "pnpm": {
    "overrides": {
      "path-to-regexp": ">=8.4.0"
    }
  },
  "devDependencies": {
    "supertest": "^7.2.2"
  }
}

PORT=3000
NODE_ENV=development

# Em desenvolvimento o rate limit fica desligado por defeito.
# Para testar limites localmente: RATE_LIMIT_ENABLED=1
# Em produção (NODE_ENV=production) os limites aplicam-se sempre.
RATE_LIMIT_ENABLED=

CLIENT_URL=http://localhost:5173

# Mínimo 32 caracteres cada (aleatórios fortes em produção).
JWT_SECRET=

REFRESH_TOKEN_SECRET=

ROOT_EMAIL=
ROOT_PASSWORD=
ROOT_NAME=

# Obrigatório para testes com credenciais fixas: escolhe UMA palavra-passe e cola-a aqui e no teu .env local.
# Depois de `pnpm run db:seed`, o admin é sempre: admin@demo.local + esta palavra-passe.
# (Organizadores e voluntários demo usam a mesma palavra-passe.)
# Exemplo de valor só para desenvolvimento local: DevTest2026!
# Se deixares vazio, o seed usa por omissão SeedDemo2026!
SEED_USER_PASSWORD=

ARGON_MEMORY_COST=65536
ARGON_TIME_COST=3
ARGON_PARALLELISM=1
ARGON_HASH_LENGTH=32

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=limpeza_praias